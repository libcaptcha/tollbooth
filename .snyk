    - '*':
        reason: XSS root cause fixed in engine.py template rendering
        created: 2026-03-30T08:19:23.214Z

  # SSRF false positives: user data flows to POST body only; URLs are hardcoded
  # static strings pointing to known third-party CAPTCHA provider APIs.
  79243356-5948-41d0-926a-a8e786d5051e:
    - '*':
        reason: >-
          False positive: user data in POST body only,
