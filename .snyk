ignore:

  # XSS: root cause fixed in engine.py (html.escape on template substitution),
  # but static taint analysis still flags the data flow through integrations.
  b1be070f-9a69-4f9e-9272-287a87a29a7a:
    - '*':
        reason: XSS root cause fixed in engine.py template rendering
        created: 2026-03-30T08:19:21.120Z
